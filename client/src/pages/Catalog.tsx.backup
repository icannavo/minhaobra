    } else {
      newSet.add(id);
    }
    setSelectedEquipments(newSet);
  };

  const toggleTeamMember = (id: number) => {
    const newSet = new Set(selectedTeamMembers);
    if (newSet.has(id)) {
      newSet.delete(id);
    } else {
      newSet.add(id);
    }
    setSelectedTeamMembers(newSet);
  };

  // Função para adicionar selecionados à obra
  const handleAddToWork = () => {
    if (!selectedWorkId) {
      toast.error("Selecione uma obra primeiro");
      return;
    }

    const selectedCount = 
      selectedEpis.size + 
      selectedTools.size + 
      selectedMaterials.size + 
      selectedEquipments.size + 
      selectedTeamMembers.size;

    if (selectedCount === 0) {
      toast.error("Selecione ao menos um item");
      return;
    }

    toast.success(`${selectedCount} itens adicionados à obra`);
    
    // Limpar seleções
    setSelectedEpis(new Set());
    setSelectedTools(new Set());
    setSelectedMaterials(new Set());
    setSelectedEquipments(new Set());
    setSelectedTeamMembers(new Set());
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-background via-background to-muted/30">
