  const handleDeselectAllEpis = () => {
    setSelectedEpis(new Set());
  };

  const handleSelectAllTools = () => {
    const filtered = filterItems(equipmentsData);
    setSelectedTools(new Set(filtered.map((item: any) => item.id)));
  };

  const handleDeselectAllTools = () => {
    setSelectedTools(new Set());
  };

  const handleSelectAllMaterials = () => {
    const filtered = filterItems(materialsData);
    setSelectedMaterials(new Set(filtered.map((item: any) => item.id)));
  };

  const handleDeselectAllMaterials = () => {
    setSelectedMaterials(new Set());
  };

  const handleSelectAllEquipments = () => {
    const filtered = filterItems(equipmentsData);
    setSelectedEquipments(new Set(filtered.map((item: any) => item.id)));
  };

  const handleDeselectAllEquipments = () => {
    setSelectedEquipments(new Set());
  };

  const handleSelectAllTeamMembers = () => {
    const filtered = filterItems(teamMembersData);
    setSelectedTeamMembers(new Set(filtered.map((item: any) => item.id)));
  };

  const handleDeselectAllTeamMembers = () => {
    setSelectedTeamMembers(new Set());
