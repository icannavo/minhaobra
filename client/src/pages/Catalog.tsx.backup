                  );
                })}
                <button
                  onClick={() => {
                    setEditingEquipment(null);
                    setIsEquipmentDialogOpen(true);
                  }}
                  className="px-4 py-2 rounded-full text-sm font-medium bg-slate-700/50 text-slate-300 hover:bg-slate-700 transition-all border-2 border-dashed border-slate-600"
                >
                  <Plus className="w-4 h-4 inline mr-1" />
                  Adicionar Ferramenta
                </button>
              </div>
            )}
